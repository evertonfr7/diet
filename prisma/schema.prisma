generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Food {
  id           Int    @id @default(autoincrement())
  nome         String
  proteina     Float
  gorduras     Float
  carboidratos Float
  unidade      String @default("g")
}

model DailySummary {
  id        Int         @id @default(autoincrement())
  date      String      @unique
  syncRecords SyncRecord[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model SyncRecord {
  id             Int         @id @default(autoincrement())
  dailySummary   DailySummary @relation(fields: [dailySummaryId], references: [id], onDelete: Cascade)
  dailySummaryId Int
  proteina       Float
  gorduras       Float
  carboidratos   Float
  syncedAt       DateTime    @default(now())
}

model Settings {
  id                 Int     @id @default(1)
  waterGoal          Int     @default(2000)
  waterNotifEnabled  Boolean @default(false)
  waterNotifInterval Int     @default(30)
  calorieTarget     Int     @default(2000)
  proteinTarget     Int     @default(150)
  carbTarget        Int     @default(250)
  fatTarget         Int     @default(70)
}
