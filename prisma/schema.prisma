generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Food {
  id           Int    @id @default(autoincrement())
  nome         String
  proteina     Float
  gorduras     Float
  carboidratos Float
}

model DailySummary {
  id           Int      @id @default(autoincrement())
  date         String   @unique
  proteina     Float
  gorduras     Float
  carboidratos Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
