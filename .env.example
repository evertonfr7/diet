# Upstash Redis (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# PostgreSQL — use Neon (https://neon.tech) para dev e prod grátis
# Na Vercel: instale a integração Neon (Storage → Create Database) e a
# DATABASE_URL é preenchida automaticamente nas env vars do projeto.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"


# IA — estimativa de macros (use qualquer provedor compatível com a API OpenAI)
#
# Opção recomendada — OpenRouter (GPT-4o-mini grátis, acesso a Claude, GPT, Llama, etc)
#   Crie sua chave em: https://openrouter.ai/keys
#   AI_BASE_URL=https://openrouter.ai/api/v1
#   AI_API_KEY=sk-xxxxxx
#   AI_MODEL=openai/gpt-4o-mini
#   
#   Headers recomendados (adicionados automaticamente nos endpoints):
#     HTTP-Referer: http://localhost:3000 (ou seu domínio de produção)
#     X-Title: Diet App
#
# Opção alternativa — Groq (Llama 3, grátis)
#   Crie sua chave em: https://console.groq.com
#   AI_BASE_URL=https://api.groq.com/openai/v1
#   AI_API_KEY=your-groq-key-here
#   AI_MODEL=llama-3.3-70b-versatile
#
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=your-ai-api-key-here
AI_MODEL=openai/gpt-4o-mini

# Timezone local para cálculo da data do dia (ex: America/Sao_Paulo)
# Sem esta variável, o servidor usa UTC (pode causar virada de dia às 21h no Brasil)
TZ_LOCAL=America/Sao_Paulo

# Timezone público (mesmo valor de TZ_LOCAL) — usado pelo frontend para formatar datas
NEXT_PUBLIC_TZ=America/Sao_Paulo

# Web Push — notificações mesmo com o app fechado
# Gere as chaves rodando: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ é exposta ao browser (chave pública); a privada fica só no servidor.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:you@example.com

# Upstash QStash — agendamento serverless para disparar os pushes
# Crie uma conta em https://console.upstash.com → QStash → Copy tokens
QSTASH_TOKEN=your-qstash-token-here
QSTASH_CURRENT_SIGNING_KEY=your-qstash-current-signing-key-here
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key-here

# URL pública do app — QStash precisa saber para onde enviar a requisição
# Na Vercel é preenchida automaticamente via VERCEL_URL.
# Em produção com domínio próprio: https://seudominio.com
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# Horário do sync automático diário (cron expression, padrão: 23:59)
# Formato: "minuto hora * * *" — usa o timezone de TZ_LOCAL
# Exemplo para 23:59: "59 23 * * *"
SYNC_CRON="59 23 * * *"

# --- Setup ---
# 1. Copie este arquivo para .env.local e preencha os valores do Upstash
# 2. Execute: pnpm install
# 3. Execute: pnpm db:migrate
# 4. Execute: pnpm dev
#
