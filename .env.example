# Upstash Redis (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# PostgreSQL — use Neon (https://neon.tech) para dev e prod grátis
# Na Vercel: instale a integração Neon (Storage → Create Database) e a
# DATABASE_URL é preenchida automaticamente nas env vars do projeto.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google AI — estimativa de macros por IA (gratuito, sem cartão)
# Gere sua chave em: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Timezone local para cálculo da data do dia (ex: America/Sao_Paulo)
# Sem esta variável, o servidor usa UTC (pode causar virada de dia às 21h no Brasil)
TZ_LOCAL=America/Sao_Paulo

# --- Setup ---
# 1. Copie este arquivo para .env.local e preencha os valores do Upstash
# 2. Execute: pnpm install
# 3. Execute: pnpm db:migrate
# 4. Execute: pnpm dev
#
# --- SSL / Proxy corporativo ---
# Se o download dos binários do Prisma falhar com "self-signed certificate",
# os scripts já incluem NODE_TLS_REJECT_UNAUTHORIZED=0 automaticamente.
# Alternativa mais segura: exporte o certificado da CA corporativa e configure
# NODE_EXTRA_CA_CERTS=/caminho/para/ca.pem no ambiente.
